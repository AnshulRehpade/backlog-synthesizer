# ==============================================================================
# Backlog Synthesizer — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# Only ANTHROPIC_API_KEY (or OPENAI_API_KEY) is required; everything else has
# sensible defaults.
# ==============================================================================

# --- LLM Provider Selection ---

# Which LLM provider to use: "anthropic" or "openai"
# Default: anthropic
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) Settings ---

# Your Anthropic API key. Get one at https://console.anthropic.com/settings/keys
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Claude model identifier. See https://docs.anthropic.com/en/docs/about-claude/models
# Default: claude-haiku-4-20250414
ANTHROPIC_MODEL=claude-haiku-4-20250414

# Maximum tokens in Claude's response
# Default: 4096
ANTHROPIC_MAX_TOKENS=4096

# Request timeout in seconds for Anthropic API calls
# Default: 60
ANTHROPIC_TIMEOUT=60

# --- OpenAI Settings ---

# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# OpenAI model identifier. See https://platform.openai.com/docs/models
# Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Custom base URL for OpenAI-compatible APIs (e.g., local LLM servers, Azure)
# Default: None (uses https://api.openai.com/v1)
OPENAI_BASE_URL=

# Request timeout in seconds for OpenAI API calls
# Default: 60
OPENAI_TIMEOUT=60

# --- Embedding Settings ---

# Sentence-transformer model for generating embeddings (runs locally, no API key needed)
# Downloaded from HuggingFace on first run (~90MB)
# Default: all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ChromaDB Vector Store Settings ---

# Name of the ChromaDB collection used for storing and querying embeddings
# Default: backlog_items
CHROMA_COLLECTION=backlog_items

# Directory for persistent ChromaDB storage. If unset, uses ephemeral in-memory mode.
# Set this to enable cross-session duplicate detection.
# Default: None (ephemeral/in-memory)
CHROMA_PERSIST_DIR=

# --- Advanced Configuration ---

# Path to a JSON config file with additional overrides.
# Keys in the file use snake_case matching PipelineConfig fields.
# Default: None
BACKLOG_SYNTHESIZER_CONFIG=

# --- Gap Detection Thresholds ---

# Similarity score at or above which items are classified as DUPLICATE
# Default: 0.85
GAP_DETECTION_DUPLICATE_THRESHOLD=0.85

# Similarity score at or above which items enter the CONFLICT zone (requires LLM confirmation)
# Items in [this value, DUPLICATE_THRESHOLD) with confirmed contradictions become CONFLICT
# Default: 0.50
GAP_DETECTION_CONFLICT_THRESHOLD=0.50

# --- ReAct Reasoning ---

# Enable LLM-driven decision-making at pipeline decision points (true/false)
# When false, the orchestrator runs as a pure sequential pipeline with no reasoning calls.
# Set to false to save LLM calls or for faster/cheaper execution.
# Default: true
REACT_REASONING_ENABLED=true
